{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/merchandise", "destination": "/merchandise.html" },
    { "source": "/community", "destination": "/community.html" },
    { "source": "/artists/kayson-woods", "destination": "/artists/kayson-woods.html" },
    { "source": "/artists/kelly-price", "destination": "/artists/kelly-price.html" },
    { "source": "/artists/jiggy-jamal", "destination": "/artists/jiggy-jamal.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/fan-dashboard", "destination": "/fan-dashboard.html" },
    { "source": "/checkout-success", "destination": "/checkout-success.html" },
    { "source": "/checkout-cancel", "destination": "/checkout-cancel.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
